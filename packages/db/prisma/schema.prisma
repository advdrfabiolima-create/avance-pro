generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Perfil {
  franqueado
  assistente
}

enum DiaSemana {
  segunda
  terca
  quarta
  quinta
  sexta
  sabado
}

enum FormaPagamento {
  pix
  cartao
  boleto
  dinheiro
}

enum StatusSessao {
  avancando_bem
  atencao
  estagnado
  critico
}

enum CodigoMateria {
  MAT
  PORT
  ING
}

enum TipoMovimento {
  entrada
  saida
}

enum StatusMovimento {
  confirmado
  pendente
  cancelado
}

enum OrigemMovimento {
  mensalidade
  matricula
  material
  salario
  aluguel
  servico
  outro
}

enum StatusCobranca {
  aguardando
  enviada
  paga
  vencida
  cancelada
}

enum StatusNotaFiscal {
  rascunho
  emitida
  cancelada
}

enum TipoRecorrencia {
  mensal
  bimestral
  trimestral
  semestral
  anual
}

enum TipoQuestao {
  objetiva
  numerica
  discursiva
}

enum StatusOcr {
  pendente
  processando
  revisao
  confirmado
  erro
}

// ─── Usuários ────────────────────────────────────────────────────────────────

model Usuario {
  id         String   @id @default(uuid())
  nome       String   @db.VarChar(100)
  email      String   @unique @db.VarChar(150)
  senhaHash  String   @map("senha_hash")
  perfil     Perfil
  ativo      Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")

  sessoesSupervisionadas Sessao[]
  progressoesRegistradas ProgressaoNivel[]
  reunioes               Reuniao[]

  @@map("usuarios")
}

// ─── Alunos ──────────────────────────────────────────────────────────────────

model Aluno {
  id              String    @id @default(uuid())
  nome            String    @db.VarChar(100)
  dataNascimento  DateTime  @map("data_nascimento") @db.Date
  escola          String?   @db.VarChar(150)
  serieEscolar    String?   @map("serie_escolar") @db.VarChar(50)
  foto            String?   @db.Text
  ativo           Boolean   @default(true)
  criadoEm       DateTime  @default(now()) @map("criado_em")

  cadastradoKsis  Boolean   @default(false) @map("cadastrado_ksis")

  // Endereço
  cep             String?   @db.VarChar(9)
  logradouro      String?   @db.VarChar(200)
  numero          String?   @db.VarChar(20)
  complemento     String?   @db.VarChar(100)
  bairro          String?   @db.VarChar(100)
  cidade          String?   @db.VarChar(100)
  estado          String?   @db.VarChar(2)

  responsaveis     ResponsavelAluno[]
  matriculas       Matricula[]
  turmas           TurmaAluno[]
  sessoesAluno     SessaoAluno[]
  pagamentos       Pagamento[]
  reunioes         Reuniao[]
  cobrancas        Cobranca[]
  notasFiscais     NotaFiscal[]
  tentativas       Tentativa[]
  errosRecorrentes ErroRecorrente[]
  sugestoes        SugestaoReforco[]
  tentativasOcr    TentativaOcr[]
  atividadesBib    AtividadeAluno[]

  @@map("alunos")
}

// ─── Responsáveis ────────────────────────────────────────────────────────────

model Responsavel {
  id           String   @id @default(uuid())
  nome         String   @db.VarChar(100)
  cpf          String?  @unique @db.VarChar(14)
  email        String   @db.VarChar(150)
  telefone     String   @db.VarChar(20)
  telefoneAlt  String?  @map("telefone_alt") @db.VarChar(20)
  criadoEm    DateTime @default(now()) @map("criado_em")

  alunos       ResponsavelAluno[]
  pagamentos   Pagamento[]
  reunioes     Reuniao[]
  notasFiscais NotaFiscal[]

  @@map("responsaveis")
}

model ResponsavelAluno {
  id             String  @id @default(uuid())
  alunoId        String  @map("aluno_id")
  responsavelId  String  @map("responsavel_id")
  parentesco     String  @db.VarChar(50)
  principal      Boolean @default(false)

  aluno       Aluno       @relation(fields: [alunoId], references: [id])
  responsavel Responsavel @relation(fields: [responsavelId], references: [id])

  @@unique([alunoId, responsavelId])
  @@map("responsaveis_aluno")
}

// ─── Matérias e Níveis ───────────────────────────────────────────────────────

model Materia {
  id     String        @id @default(uuid())
  nome   String        @db.VarChar(50)
  codigo CodigoMateria @unique

  niveis     Nivel[]
  matriculas Matricula[]
  exercicios Exercicio[]

  @@map("materias")
}

model Nivel {
  id        String @id @default(uuid())
  materiaId String @map("materia_id")
  codigo    String @db.VarChar(5)
  descricao String @db.VarChar(255)
  ordem     Int

  materia             Materia           @relation(fields: [materiaId], references: [id])
  matriculasAtuais    Matricula[]       @relation("NivelAtual")
  sessoesAluno        SessaoAluno[]
  progressoesAnteriores ProgressaoNivel[] @relation("NivelAnterior")
  progressoesNovas    ProgressaoNivel[] @relation("NivelNovo")
  exercicios          Exercicio[]

  @@unique([materiaId, codigo])
  @@map("niveis")
}

// ─── Matrículas ──────────────────────────────────────────────────────────────

model Matricula {
  id            String    @id @default(uuid())
  alunoId       String    @map("aluno_id")
  materiaId     String    @map("materia_id")
  nivelAtualId  String    @map("nivel_atual_id")
  dataInicio    DateTime  @map("data_inicio") @db.Date
  dataFim       DateTime? @map("data_fim") @db.Date
  ativo         Boolean   @default(true)

  aluno       Aluno       @relation(fields: [alunoId], references: [id])
  materia     Materia     @relation(fields: [materiaId], references: [id])
  nivelAtual  Nivel       @relation("NivelAtual", fields: [nivelAtualId], references: [id])

  sessoesAluno SessaoAluno[]
  progressoes  ProgressaoNivel[]
  pagamentos   Pagamento[]

  @@map("matriculas")
}

model ProgressaoNivel {
  id               String   @id @default(uuid())
  matriculaId      String   @map("matricula_id")
  nivelAnteriorId  String   @map("nivel_anterior_id")
  nivelNovoId      String   @map("nivel_novo_id")
  data             DateTime @db.Date
  usuarioId        String   @map("usuario_id")
  motivo           String?  @db.Text

  matricula     Matricula @relation(fields: [matriculaId], references: [id])
  nivelAnterior Nivel     @relation("NivelAnterior", fields: [nivelAnteriorId], references: [id])
  nivelNovo     Nivel     @relation("NivelNovo", fields: [nivelNovoId], references: [id])
  usuario       Usuario   @relation(fields: [usuarioId], references: [id])

  @@map("progressao_niveis")
}

// ─── Turmas e Sessões ────────────────────────────────────────────────────────

model Turma {
  id             String    @id @default(uuid())
  diaSemana      DiaSemana @map("dia_semana")
  horarioInicio  String    @map("horario_inicio") @db.VarChar(5)
  horarioFim     String    @map("horario_fim") @db.VarChar(5)
  capacidade     Int

  alunos  TurmaAluno[]
  sessoes Sessao[]

  @@map("turmas")
}

model TurmaAluno {
  id          String    @id @default(uuid())
  turmaId     String    @map("turma_id")
  alunoId     String    @map("aluno_id")
  dataInicio  DateTime  @map("data_inicio") @db.Date
  dataFim     DateTime? @map("data_fim") @db.Date

  turma Turma @relation(fields: [turmaId], references: [id])
  aluno Aluno @relation(fields: [alunoId], references: [id])

  @@map("turma_alunos")
}

model Sessao {
  id           String   @id @default(uuid())
  turmaId      String   @map("turma_id")
  data         DateTime @db.Date
  assistenteId String   @map("assistente_id")
  observacoes  String?  @db.Text
  criadoEm    DateTime @default(now()) @map("criado_em")

  turma      Turma       @relation(fields: [turmaId], references: [id])
  assistente Usuario     @relation(fields: [assistenteId], references: [id])
  alunos     SessaoAluno[]

  @@unique([turmaId, data])
  @@map("sessoes")
}

model SessaoAluno {
  id             String        @id @default(uuid())
  sessaoId       String        @map("sessao_id")
  alunoId        String        @map("aluno_id")
  matriculaId    String        @map("matricula_id")
  presente       Boolean       @default(true)
  folhasFeitas   Int?          @map("folhas_feitas")
  acertos        Int?
  erros          Int?
  tempoMinutos   Int?          @map("tempo_minutos")
  nivelId        String?       @map("nivel_id")
  materialCodigo String?       @map("material_codigo") @db.VarChar(20)
  statusSessao   StatusSessao? @map("status_sessao")
  observacao     String?       @db.Text

  sessao    Sessao    @relation(fields: [sessaoId], references: [id])
  aluno     Aluno     @relation(fields: [alunoId], references: [id])
  matricula Matricula @relation(fields: [matriculaId], references: [id])
  nivel     Nivel?    @relation(fields: [nivelId], references: [id])

  @@unique([sessaoId, alunoId, matriculaId])
  @@map("sessao_alunos")
}

// ─── Reuniões ────────────────────────────────────────────────────────────────

model Reuniao {
  id             String   @id @default(uuid())
  alunoId        String   @map("aluno_id")
  responsavelId  String?  @map("responsavel_id")
  usuarioId      String   @map("usuario_id")
  data           DateTime @db.Date
  descricao      String   @db.Text
  tipo           String   @default("geral") @db.VarChar(50)
  criadoEm      DateTime @default(now()) @map("criado_em")

  aluno       Aluno        @relation(fields: [alunoId], references: [id])
  responsavel Responsavel? @relation(fields: [responsavelId], references: [id])
  usuario     Usuario      @relation(fields: [usuarioId], references: [id])

  @@map("reunioes")
}

// ─── Pagamentos / Mensalidades ───────────────────────────────────────────────

model Pagamento {
  id             String          @id @default(uuid())
  alunoId        String          @map("aluno_id")
  matriculaId    String          @map("matricula_id")
  responsavelId  String          @map("responsavel_id")
  mesReferencia  DateTime        @map("mes_referencia") @db.Date
  valor          Decimal         @db.Decimal(10, 2)
  vencimento     DateTime        @db.Date
  pagoEm         DateTime?       @map("pago_em") @db.Date
  formaPagamento FormaPagamento? @map("forma_pagamento")
  observacao     String?         @db.Text
  conciliado     Boolean         @default(false)
  conciliadoEm   DateTime?       @map("conciliado_em") @db.Date

  aluno       Aluno       @relation(fields: [alunoId], references: [id])
  matricula   Matricula   @relation(fields: [matriculaId], references: [id])
  responsavel Responsavel @relation(fields: [responsavelId], references: [id])
  cobrancas   Cobranca[]
  movimentos  MovimentoFinanceiro[]

  @@unique([matriculaId, mesReferencia])
  @@map("pagamentos")
}

// ─── Cobranças ───────────────────────────────────────────────────────────────

model Cobranca {
  id           String         @id @default(uuid())
  alunoId      String         @map("aluno_id")
  pagamentoId  String?        @map("pagamento_id")
  valor        Decimal        @db.Decimal(10, 2)
  vencimento   DateTime       @db.Date
  status       StatusCobranca @default(aguardando)
  descricao    String?        @db.VarChar(255)
  nossoNumero    String?        @map("nosso_numero") @db.VarChar(100)
  linhaDigitavel String?        @map("linha_digitavel") @db.VarChar(200)
  asaasId        String?        @map("asaas_id") @db.VarChar(100)
  provider       String?        @db.VarChar(20)
  tipo           String?        @db.VarChar(20)
  pixQrCode      String?        @map("pix_qr_code") @db.Text
  pixChave       String?        @map("pix_chave") @db.Text
  boletoUrl      String?        @map("boleto_url") @db.Text
  criadoEm      DateTime       @default(now()) @map("criado_em")
  pagoEm         DateTime?      @map("pago_em") @db.Date

  bankAccountId    String?    @map("bank_account_id")

  aluno            Aluno               @relation(fields: [alunoId], references: [id])
  pagamento        Pagamento?          @relation(fields: [pagamentoId], references: [id])
  bankAccount      BillingBankAccount? @relation(fields: [bankAccountId], references: [id])
  reconciliacoes   BillingReconciliation[]
  actionLogs       BillingActionLog[]
  cnabOccurrences  CnabOccurrence[]

  @@map("cobrancas")
}

// ─── Movimento Financeiro ────────────────────────────────────────────────────

model MovimentoFinanceiro {
  id           String          @id @default(uuid())
  tipo         TipoMovimento
  origem       OrigemMovimento @default(outro)
  descricao    String          @db.VarChar(255)
  valor        Decimal         @db.Decimal(10, 2)
  data         DateTime        @db.Date
  status       StatusMovimento @default(confirmado)
  pagamentoId  String?         @map("pagamento_id")
  observacao   String?         @db.Text
  criadoEm    DateTime        @default(now()) @map("criado_em")

  pagamento        Pagamento? @relation(fields: [pagamentoId], references: [id])
  reconciliacoes   BillingReconciliation[]

  @@map("movimentos_financeiros")
}

// ─── Bancos / CNAB ────────────────────────────────────────────────────────────

model BankCatalog {
  id               String   @id @default(uuid())
  code             String   @unique @db.VarChar(10)
  name             String   @db.VarChar(100)
  /// CNAB 240, CNAB 400, CNAB 240/400
  cnabSupport      String   @default("") @map("cnab_support") @db.VarChar(20)
  cnab240Supported Boolean  @default(false) @map("cnab240_supported")
  cnab400Supported Boolean  @default(false) @map("cnab400_supported")
  isActive         Boolean  @default(true) @map("is_active")
  /// JSON — observações, status de homologação, etc.
  metadata         String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  accounts BillingBankAccount[]

  @@map("bank_catalog")
}

model BillingBankAccount {
  id                  String   @id @default(uuid())
  bankCode            String   @map("bank_code") @db.VarChar(10)
  bankName            String   @map("bank_name") @db.VarChar(100)
  accountName         String   @map("account_name") @db.VarChar(150)
  agreementCode       String?  @map("agreement_code") @db.VarChar(50)
  walletCode          String?  @map("wallet_code") @db.VarChar(10)
  agency              String   @db.VarChar(10)
  agencyDigit         String?  @map("agency_digit") @db.VarChar(2)
  accountNumber       String   @map("account_number") @db.VarChar(20)
  accountDigit        String?  @map("account_digit") @db.VarChar(2)
  beneficiaryName     String   @map("beneficiary_name") @db.VarChar(100)
  beneficiaryDocument String   @map("beneficiary_document") @db.VarChar(20)
  /// cnab240 | cnab400
  remittanceLayout    String   @default("cnab240") @map("remittance_layout") @db.VarChar(10)
  fileNamingPattern   String?  @map("file_naming_pattern") @db.VarChar(100)
  sequentialFileNumber Int     @default(1) @map("sequential_file_number")
  isDefault           Boolean  @default(false) @map("is_default")
  isActive            Boolean  @default(true) @map("is_active")
  instructions        String?  @db.Text
  protestDays         Int      @default(0) @map("protest_days")
  autoDropDays        Int      @default(0) @map("auto_drop_days")
  /// JSON — future API credentials, extra config
  metadata            String?  @db.Text
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  bank      BankCatalog @relation(fields: [bankCode], references: [code])
  cnabFiles CnabFile[]
  cobrancas Cobranca[]

  @@map("billing_bank_accounts")
}

model CnabFile {
  id             String    @id @default(uuid())
  bankAccountId  String    @map("bank_account_id")
  /// remessa | retorno
  type           String    @db.VarChar(10)
  fileName       String    @map("file_name") @db.VarChar(200)
  /// cnab240 | cnab400
  layoutType     String    @map("layout_type") @db.VarChar(10)
  /// pendente | processado | erro
  status         String    @default("pendente") @db.VarChar(20)
  totalRecords   Int?      @map("total_records")
  processedCount Int?      @map("processed_count")
  errorCount     Int?      @map("error_count")
  generatedAt    DateTime? @map("generated_at")
  importedAt     DateTime? @map("imported_at")
  processedAt    DateTime? @map("processed_at")
  createdBy      String?   @map("created_by") @db.VarChar(100)
  metadata       String?   @db.Text
  rawContent     String?   @map("raw_content") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  bankAccount BillingBankAccount @relation(fields: [bankAccountId], references: [id])
  occurrences CnabOccurrence[]

  @@map("cnab_files")
}

model CnabOccurrence {
  id                   String    @id @default(uuid())
  cnabFileId           String    @map("cnab_file_id")
  billingChargeId      String?   @map("billing_charge_id")
  occurrenceCode       String    @map("occurrence_code") @db.VarChar(10)
  occurrenceDescription String   @map("occurrence_description") @db.VarChar(200)
  ourNumber            String?   @map("our_number") @db.VarChar(50)
  documentNumber       String?   @map("document_number") @db.VarChar(50)
  amount               Decimal?  @db.Decimal(15, 2)
  paidAmount           Decimal?  @map("paid_amount") @db.Decimal(15, 2)
  occurrenceDate       DateTime? @map("occurrence_date") @db.Date
  creditDate           DateTime? @map("credit_date") @db.Date
  rawLine              String?   @map("raw_line") @db.Text
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  cnabFile      CnabFile  @relation(fields: [cnabFileId], references: [id])
  billingCharge Cobranca? @relation(fields: [billingChargeId], references: [id])

  @@map("cnab_occurrences")
}

// ─── Régua de Cobrança ────────────────────────────────────────────────────────

model BillingRule {
  id         String   @id @default(uuid())
  name       String   @db.VarChar(150)
  /// before | on_due | after
  eventType  String   @map("event_type") @db.VarChar(20)
  offsetDays Int      @default(0) @map("offset_days")
  /// whatsapp | internal | email | webhook
  channel      String   @db.VarChar(30)
  template     String   @db.Text
  emailSubject String?  @map("email_subject") @db.VarChar(255)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  actionLogs BillingActionLog[]

  @@map("billing_rules")
}

model BillingActionLog {
  id              String    @id @default(uuid())
  cobrancaId      String    @map("cobranca_id")
  billingRuleId   String?   @map("billing_rule_id")
  /// whatsapp_sent | whatsapp_prepared | internal_alert | manual | ignored
  actionType      String    @map("action_type") @db.VarChar(50)
  channel         String    @db.VarChar(30)
  messageSnapshot String?   @map("message_snapshot") @db.Text
  /// pendente | enviado | ignorado | erro
  status          String    @default("pendente") @db.VarChar(20)
  triggeredAt     DateTime  @default(now()) @map("triggered_at")
  triggeredBy     String?   @map("triggered_by") @db.VarChar(100)
  metadata        String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  cobranca    Cobranca     @relation(fields: [cobrancaId], references: [id])
  billingRule BillingRule? @relation(fields: [billingRuleId], references: [id])

  @@map("billing_action_logs")
}

// ─── Automação da Régua de Cobrança ──────────────────────────────────────────

model BillingAutomationRun {
  id             String    @id @default(uuid())
  /// running | completed | error
  status         String    @default("running") @db.VarChar(20)
  startedAt      DateTime  @default(now()) @map("started_at")
  finishedAt     DateTime? @map("finished_at")
  processedCount Int       @default(0) @map("processed_count")
  errorCount     Int       @default(0) @map("error_count")
  skippedCount   Int       @default(0) @map("skipped_count")
  /// Mensagem de erro fatal ou detalhes adicionais
  details        String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("billing_automation_runs")
}

// ─── Conciliação Financeira ───────────────────────────────────────────────────

model BillingReconciliation {
  id             String    @id @default(uuid())
  cobrancaId     String    @map("cobranca_id")
  movimentoId    String?   @map("movimento_id")
  provider       String?   @db.VarChar(20)
  /// pendente | conciliado | ignorado | divergente
  status         String    @default("pendente") @db.VarChar(20)
  /// auto | manual | imported | webhook | cnab
  matchType      String?   @map("match_type") @db.VarChar(20)
  notas          String?   @db.Text
  reconciladoEm  DateTime? @map("reconciliado_em")
  reconciladoPor String?   @map("reconciliado_por") @db.VarChar(100)
  criadoEm       DateTime  @default(now()) @map("criado_em")
  atualizadoEm   DateTime  @updatedAt @map("atualizado_em")

  cobranca  Cobranca             @relation(fields: [cobrancaId], references: [id])
  movimento MovimentoFinanceiro? @relation(fields: [movimentoId], references: [id])

  @@unique([cobrancaId])
  @@map("billing_reconciliations")
}

// ─── Recorrências ────────────────────────────────────────────────────────────

model ConfigRecorrencia {
  id              String          @id @default(uuid())
  nome            String          @db.VarChar(100)
  valor           Decimal         @db.Decimal(10, 2)
  periodicidade   TipoRecorrencia
  diaVencimento   Int             @map("dia_vencimento")
  dataInicio      DateTime        @map("data_inicio") @db.Date
  dataFim         DateTime?       @map("data_fim") @db.Date
  ativo           Boolean         @default(true)
  descricao       String?         @db.VarChar(255)
  criadoEm       DateTime        @default(now()) @map("criado_em")

  @@map("config_recorrencias")
}

// ─── Notas Fiscais ───────────────────────────────────────────────────────────

model NotaFiscal {
  id            String           @id @default(uuid())
  alunoId       String           @map("aluno_id")
  responsavelId String?          @map("responsavel_id")
  numero        String?          @db.VarChar(50)
  valor         Decimal          @db.Decimal(10, 2)
  competencia   DateTime         @db.Date
  status        StatusNotaFiscal @default(rascunho)
  descricao     String?          @db.VarChar(255)
  xmlUrl        String?          @map("xml_url") @db.VarChar(500)
  criadoEm     DateTime         @default(now()) @map("criado_em")
  emitidaEm    DateTime?        @map("emitida_em")

  aluno       Aluno        @relation(fields: [alunoId], references: [id])
  responsavel Responsavel? @relation(fields: [responsavelId], references: [id])

  @@map("notas_fiscais")
}

// ─── Configurações da Empresa ────────────────────────────────────────────────

model ConfigEmpresa {
  id              String   @id @default(uuid())
  nome            String   @db.VarChar(200)
  cnpj            String?  @db.VarChar(18)
  logo            String?  @db.Text
  cep             String?  @db.VarChar(9)
  rua             String?  @db.VarChar(200)
  numero          String?  @db.VarChar(20)
  complemento     String?  @db.VarChar(100)
  bairro          String?  @db.VarChar(100)
  cidade          String?  @db.VarChar(100)
  estado          String?  @db.VarChar(2)
  /// Nome exibido como remetente nos e-mails enviados pela unidade.
  /// Fallback: nome da unidade → BREVO_SENDER_NAME
  emailSenderName String?  @map("email_sender_name") @db.VarChar(200)
  atualizadoEm    DateTime @default(now()) @updatedAt @map("atualizado_em")

  @@map("config_empresa")
}

// ─── Gateway de Pagamento ─────────────────────────────────────────────────────

model ConfigGateway {
  id        String   @id @default(uuid())
  tipo      String   @db.VarChar(50)
  ambiente  String   @db.VarChar(20)
  apiKey    String   @db.Text @map("api_key")
  ativo     Boolean  @default(true)
  criadoEm DateTime @default(now()) @map("criado_em")

  @@map("config_gateway")
}

// ─── Exercícios e Correção Inteligente ───────────────────────────────────────

model Exercicio {
  id          String   @id @default(uuid())
  titulo      String   @db.VarChar(200)
  descricao   String?  @db.Text
  materiaId   String?  @map("materia_id")
  nivelId     String?  @map("nivel_id")
  ativo       Boolean  @default(true)
  criadoEm   DateTime @default(now()) @map("criado_em")

  materia       Materia?       @relation(fields: [materiaId], references: [id])
  nivel         Nivel?         @relation(fields: [nivelId], references: [id])
  questoes      Questao[]
  tentativas    Tentativa[]
  tentativasOcr TentativaOcr[]

  @@map("exercicios")
}

model Questao {
  id          String      @id @default(uuid())
  exercicioId String      @map("exercicio_id")
  enunciado   String      @db.Text
  tipo        TipoQuestao
  ordem       Int         @default(0)
  pontos      Decimal     @default(1) @db.Decimal(5, 2)

  exercicio               Exercicio               @relation(fields: [exercicioId], references: [id], onDelete: Cascade)
  alternativas            Alternativa[]
  respostaCorreta         RespostaCorreta?
  respostasAluno          RespostaAluno[]
  errosRecorrentes        ErroRecorrente[]
  respostasOcrDetectadas  RespostaOcrDetectada[]

  @@map("questoes")
}

model Alternativa {
  id        String  @id @default(uuid())
  questaoId String  @map("questao_id")
  letra     String  @db.VarChar(1)
  texto     String  @db.Text

  questao          Questao          @relation(fields: [questaoId], references: [id], onDelete: Cascade)
  respostasAluno   RespostaAluno[]

  @@map("alternativas")
}

model RespostaCorreta {
  id            String   @id @default(uuid())
  questaoId     String   @unique @map("questao_id")
  alternativaId String?  @map("alternativa_id")
  valorNumerico Decimal? @map("valor_numerico") @db.Decimal(15, 4)
  tolerancia    Decimal? @db.Decimal(10, 4)
  textoEsperado String?  @map("texto_esperado") @db.Text

  questao Questao @relation(fields: [questaoId], references: [id], onDelete: Cascade)

  @@map("respostas_corretas")
}

model Tentativa {
  id           String    @id @default(uuid())
  alunoId      String    @map("aluno_id")
  exercicioId  String    @map("exercicio_id")
  iniciadaEm   DateTime  @default(now()) @map("iniciada_em")
  finalizadaEm DateTime? @map("finalizada_em")
  pontuacao    Decimal?  @db.Decimal(5, 2)
  totalPontos  Decimal?  @map("total_pontos") @db.Decimal(5, 2)
  corrigida    Boolean   @default(false)

  aluno          Aluno           @relation(fields: [alunoId], references: [id])
  exercicio      Exercicio       @relation(fields: [exercicioId], references: [id])
  respostasAluno RespostaAluno[]
  tentativaOcr   TentativaOcr?

  @@map("tentativas")
}

model RespostaAluno {
  id            String   @id @default(uuid())
  tentativaId   String   @map("tentativa_id")
  questaoId     String   @map("questao_id")
  alternativaId String?  @map("alternativa_id")
  valorNumerico Decimal? @map("valor_numerico") @db.Decimal(15, 4)
  textoResposta String?  @map("texto_resposta") @db.Text
  correta       Boolean?
  pontosObtidos Decimal? @map("pontos_obtidos") @db.Decimal(5, 2)

  tentativa   Tentativa    @relation(fields: [tentativaId], references: [id], onDelete: Cascade)
  questao     Questao      @relation(fields: [questaoId], references: [id])
  alternativa Alternativa? @relation(fields: [alternativaId], references: [id])

  @@unique([tentativaId, questaoId])
  @@map("respostas_aluno")
}

model ErroRecorrente {
  id               String   @id @default(uuid())
  alunoId          String   @map("aluno_id")
  questaoId        String   @map("questao_id")
  contagem         Int      @default(1)
  ultimaOcorrencia DateTime @default(now()) @map("ultima_ocorrencia")
  resolvido        Boolean  @default(false)

  aluno     Aluno            @relation(fields: [alunoId], references: [id])
  questao   Questao          @relation(fields: [questaoId], references: [id])
  sugestoes SugestaoReforco[]

  @@unique([alunoId, questaoId])
  @@map("erros_recorrentes")
}

model SugestaoReforco {
  id               String   @id @default(uuid())
  alunoId          String   @map("aluno_id")
  erroRecorrenteId String   @map("erro_recorrente_id")
  texto            String   @db.Text
  criadoEm        DateTime @default(now()) @map("criado_em")
  visualizada      Boolean  @default(false)

  aluno          Aluno          @relation(fields: [alunoId], references: [id])
  erroRecorrente ErroRecorrente @relation(fields: [erroRecorrenteId], references: [id])

  @@map("sugestoes_reforco")
}

// ─── OCR — Correção por Fotografia ───────────────────────────────────────────

model TentativaOcr {
  id            String    @id @default(uuid())
  alunoId       String    @map("aluno_id")
  exercicioId   String    @map("exercicio_id")
  arquivoBase64 String    @db.Text @map("arquivo_base64")
  tipoArquivo   String    @default("image/jpeg") @map("tipo_arquivo") @db.VarChar(30)
  textoOcr      String?   @db.Text @map("texto_ocr")
  status        StatusOcr @default(pendente)
  erroMensagem  String?   @db.Text @map("erro_mensagem")
  tentativaId   String?   @unique @map("tentativa_id")
  criadoEm     DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  aluno               Aluno                  @relation(fields: [alunoId], references: [id])
  exercicio           Exercicio              @relation(fields: [exercicioId], references: [id])
  tentativa           Tentativa?             @relation(fields: [tentativaId], references: [id])
  respostasDetectadas RespostaOcrDetectada[]

  @@map("tentativas_ocr")
}

model RespostaOcrDetectada {
  id              String   @id @default(uuid())
  tentativaOcrId  String   @map("tentativa_ocr_id")
  questaoOrdem    Int      @map("questao_ordem")
  questaoId       String?  @map("questao_id")
  tipoQuestao     String   @map("tipo_questao") @db.VarChar(20)
  // O que o OCR detectou (nunca muda após processamento)
  letraDetectada  String?  @map("letra_detectada") @db.VarChar(1)
  valorDetectado  Decimal? @map("valor_detectado") @db.Decimal(15, 4)
  confianca       Decimal? @db.Decimal(4, 3)
  // O que o usuário confirmou na revisão (pode diferir do OCR)
  letraFinal      String?  @map("letra_final") @db.VarChar(1)
  valorFinal      Decimal? @map("valor_final") @db.Decimal(15, 4)
  revisadaManual  Boolean  @default(false) @map("revisada_manual")

  tentativaOcr TentativaOcr @relation(fields: [tentativaOcrId], references: [id], onDelete: Cascade)
  questao      Questao?      @relation(fields: [questaoId], references: [id])

  @@map("respostas_ocr_detectadas")
}

// ─── Biblioteca Inteligente de Exercícios ─────────────────────────────────────

enum DisciplinaBib {
  matematica
  portugues
  ingles
}

enum DificuldadeBib {
  facil
  medio
  dificil
}

enum TipoBib {
  objetivo
  numerico
  texto
}

enum StatusBib {
  rascunho
  publicado
  arquivado
}

enum OrigemBib {
  manual
  ia
}

enum DestinatarioBib {
  aluno
  turma
}

model BibExercicio {
  id            String        @id @default(uuid())
  disciplina    DisciplinaBib
  topico        String        @db.VarChar(100)
  subtopico     String?       @db.VarChar(100)
  nivel         String        @db.VarChar(10)
  dificuldade   DificuldadeBib
  tipo          TipoBib
  enunciado     String        @db.Text
  opcoes        Json?
  resposta      String        @db.Text
  explicacao    String        @db.Text
  tags          Json          @default("[]")
  origem        OrigemBib     @default(manual)
  status        StatusBib     @default(rascunho)
  criadoPorId   String?       @map("criado_por_id")
  revisadoPorId String?       @map("revisado_por_id")
  criadoEm      DateTime      @default(now()) @map("criado_em")
  atualizadoEm  DateTime      @updatedAt @map("atualizado_em")

  trilhaItens TrilhaItem[]
  listaItens  ListaItem[]
  atividades  AtividadeAluno[]

  @@map("bib_exercicios")
}

model TrilhaPedagogica {
  id           String        @id @default(uuid())
  nome         String        @db.VarChar(200)
  disciplina   DisciplinaBib
  descricao    String?       @db.Text
  nivelInicio  String        @db.VarChar(10) @map("nivel_inicio")
  nivelFim     String        @db.VarChar(10) @map("nivel_fim")
  status       StatusBib     @default(rascunho)
  criadoEm     DateTime      @default(now()) @map("criado_em")
  atualizadoEm DateTime      @updatedAt @map("atualizado_em")

  itens TrilhaItem[]

  @@map("trilhas_pedagogicas")
}

model TrilhaItem {
  id          String @id @default(uuid())
  trilhaId    String @map("trilha_id")
  exercicioId String @map("exercicio_id")
  ordemIndex  Int    @map("ordem_index")

  trilha    TrilhaPedagogica @relation(fields: [trilhaId], references: [id], onDelete: Cascade)
  exercicio BibExercicio     @relation(fields: [exercicioId], references: [id])

  @@unique([trilhaId, exercicioId])
  @@map("trilha_itens")
}

model ListaExercicio {
  id           String          @id @default(uuid())
  titulo       String          @db.VarChar(200)
  disciplina   DisciplinaBib?
  descricao    String?         @db.Text
  criadoPorId  String?         @map("criado_por_id")
  destinatario DestinatarioBib @default(aluno)
  destinoId    String?         @map("destino_id")
  status       StatusBib       @default(rascunho)
  criadoEm     DateTime        @default(now()) @map("criado_em")
  atualizadoEm DateTime        @updatedAt @map("atualizado_em")

  itens      ListaItem[]
  atividades AtividadeAluno[]

  @@map("listas_exercicios")
}

model ListaItem {
  id          String @id @default(uuid())
  listaId     String @map("lista_id")
  exercicioId String @map("exercicio_id")
  ordemIndex  Int    @map("ordem_index")

  lista     ListaExercicio @relation(fields: [listaId], references: [id], onDelete: Cascade)
  exercicio BibExercicio   @relation(fields: [exercicioId], references: [id])

  @@unique([listaId, exercicioId])
  @@map("lista_itens")
}

model AtividadeAluno {
  id              String   @id @default(uuid())
  alunoId         String   @map("aluno_id")
  exercicioId     String   @map("exercicio_id")
  listaId         String?  @map("lista_id")
  respostaEnviada String   @db.Text @map("resposta_enviada")
  correto         Boolean
  tempoSegundos   Int?     @map("tempo_segundos")
  tentativaNum    Int      @default(1) @map("tentativa_num")
  revisadoManual  Boolean  @default(false) @map("revisado_manual")
  criadoEm        DateTime @default(now()) @map("criado_em")

  aluno     Aluno          @relation(fields: [alunoId], references: [id])
  exercicio BibExercicio   @relation(fields: [exercicioId], references: [id])
  lista     ListaExercicio? @relation(fields: [listaId], references: [id])

  @@map("atividades_aluno")
}
