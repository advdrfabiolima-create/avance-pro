generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Perfil {
  franqueado
  assistente
}

enum DiaSemana {
  segunda
  terca
  quarta
  quinta
  sexta
  sabado
}

enum FormaPagamento {
  pix
  cartao
  boleto
  dinheiro
}

enum StatusSessao {
  avancando_bem
  atencao
  estagnado
  critico
}

enum CodigoMateria {
  MAT
  PORT
  ING
}

enum TipoMovimento {
  entrada
  saida
}

enum StatusMovimento {
  confirmado
  pendente
  cancelado
}

enum OrigemMovimento {
  mensalidade
  matricula
  material
  salario
  aluguel
  servico
  outro
}

enum StatusCobranca {
  aguardando
  enviada
  paga
  vencida
  cancelada
}

enum StatusNotaFiscal {
  rascunho
  emitida
  cancelada
}

enum TipoRecorrencia {
  mensal
  bimestral
  trimestral
  semestral
  anual
}

enum TipoQuestao {
  objetiva
  numerica
  discursiva
}

enum StatusOcr {
  pendente
  processando
  revisao
  confirmado
  erro
}

// ─── Usuários ────────────────────────────────────────────────────────────────

model Usuario {
  id         String   @id @default(uuid())
  nome       String   @db.VarChar(100)
  email      String   @unique @db.VarChar(150)
  senhaHash  String   @map("senha_hash")
  perfil     Perfil
  ativo      Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")

  sessoesSupervisionadas Sessao[]
  progressoesRegistradas ProgressaoNivel[]
  reunioes               Reuniao[]

  @@map("usuarios")
}

// ─── Alunos ──────────────────────────────────────────────────────────────────

model Aluno {
  id              String    @id @default(uuid())
  nome            String    @db.VarChar(100)
  dataNascimento  DateTime  @map("data_nascimento") @db.Date
  escola          String?   @db.VarChar(150)
  serieEscolar    String?   @map("serie_escolar") @db.VarChar(50)
  foto            String?   @db.Text
  ativo           Boolean   @default(true)
  criadoEm       DateTime  @default(now()) @map("criado_em")

  responsaveis     ResponsavelAluno[]
  matriculas       Matricula[]
  turmas           TurmaAluno[]
  sessoesAluno     SessaoAluno[]
  pagamentos       Pagamento[]
  reunioes         Reuniao[]
  cobrancas        Cobranca[]
  notasFiscais     NotaFiscal[]
  tentativas       Tentativa[]
  errosRecorrentes ErroRecorrente[]
  sugestoes        SugestaoReforco[]
  tentativasOcr    TentativaOcr[]

  @@map("alunos")
}

// ─── Responsáveis ────────────────────────────────────────────────────────────

model Responsavel {
  id           String   @id @default(uuid())
  nome         String   @db.VarChar(100)
  cpf          String?  @unique @db.VarChar(14)
  email        String   @db.VarChar(150)
  telefone     String   @db.VarChar(20)
  telefoneAlt  String?  @map("telefone_alt") @db.VarChar(20)
  criadoEm    DateTime @default(now()) @map("criado_em")

  alunos       ResponsavelAluno[]
  pagamentos   Pagamento[]
  reunioes     Reuniao[]
  notasFiscais NotaFiscal[]

  @@map("responsaveis")
}

model ResponsavelAluno {
  id             String  @id @default(uuid())
  alunoId        String  @map("aluno_id")
  responsavelId  String  @map("responsavel_id")
  parentesco     String  @db.VarChar(50)
  principal      Boolean @default(false)

  aluno       Aluno       @relation(fields: [alunoId], references: [id])
  responsavel Responsavel @relation(fields: [responsavelId], references: [id])

  @@unique([alunoId, responsavelId])
  @@map("responsaveis_aluno")
}

// ─── Matérias e Níveis ───────────────────────────────────────────────────────

model Materia {
  id     String        @id @default(uuid())
  nome   String        @db.VarChar(50)
  codigo CodigoMateria @unique

  niveis     Nivel[]
  matriculas Matricula[]
  exercicios Exercicio[]

  @@map("materias")
}

model Nivel {
  id        String @id @default(uuid())
  materiaId String @map("materia_id")
  codigo    String @db.VarChar(5)
  descricao String @db.VarChar(255)
  ordem     Int

  materia             Materia           @relation(fields: [materiaId], references: [id])
  matriculasAtuais    Matricula[]       @relation("NivelAtual")
  sessoesAluno        SessaoAluno[]
  progressoesAnteriores ProgressaoNivel[] @relation("NivelAnterior")
  progressoesNovas    ProgressaoNivel[] @relation("NivelNovo")
  exercicios          Exercicio[]

  @@unique([materiaId, codigo])
  @@map("niveis")
}

// ─── Matrículas ──────────────────────────────────────────────────────────────

model Matricula {
  id            String    @id @default(uuid())
  alunoId       String    @map("aluno_id")
  materiaId     String    @map("materia_id")
  nivelAtualId  String    @map("nivel_atual_id")
  dataInicio    DateTime  @map("data_inicio") @db.Date
  dataFim       DateTime? @map("data_fim") @db.Date
  ativo         Boolean   @default(true)

  aluno       Aluno       @relation(fields: [alunoId], references: [id])
  materia     Materia     @relation(fields: [materiaId], references: [id])
  nivelAtual  Nivel       @relation("NivelAtual", fields: [nivelAtualId], references: [id])

  sessoesAluno SessaoAluno[]
  progressoes  ProgressaoNivel[]
  pagamentos   Pagamento[]

  @@map("matriculas")
}

model ProgressaoNivel {
  id               String   @id @default(uuid())
  matriculaId      String   @map("matricula_id")
  nivelAnteriorId  String   @map("nivel_anterior_id")
  nivelNovoId      String   @map("nivel_novo_id")
  data             DateTime @db.Date
  usuarioId        String   @map("usuario_id")
  motivo           String?  @db.Text

  matricula     Matricula @relation(fields: [matriculaId], references: [id])
  nivelAnterior Nivel     @relation("NivelAnterior", fields: [nivelAnteriorId], references: [id])
  nivelNovo     Nivel     @relation("NivelNovo", fields: [nivelNovoId], references: [id])
  usuario       Usuario   @relation(fields: [usuarioId], references: [id])

  @@map("progressao_niveis")
}

// ─── Turmas e Sessões ────────────────────────────────────────────────────────

model Turma {
  id             String    @id @default(uuid())
  diaSemana      DiaSemana @map("dia_semana")
  horarioInicio  String    @map("horario_inicio") @db.VarChar(5)
  horarioFim     String    @map("horario_fim") @db.VarChar(5)
  capacidade     Int

  alunos  TurmaAluno[]
  sessoes Sessao[]

  @@map("turmas")
}

model TurmaAluno {
  id          String    @id @default(uuid())
  turmaId     String    @map("turma_id")
  alunoId     String    @map("aluno_id")
  dataInicio  DateTime  @map("data_inicio") @db.Date
  dataFim     DateTime? @map("data_fim") @db.Date

  turma Turma @relation(fields: [turmaId], references: [id])
  aluno Aluno @relation(fields: [alunoId], references: [id])

  @@map("turma_alunos")
}

model Sessao {
  id           String   @id @default(uuid())
  turmaId      String   @map("turma_id")
  data         DateTime @db.Date
  assistenteId String   @map("assistente_id")
  observacoes  String?  @db.Text
  criadoEm    DateTime @default(now()) @map("criado_em")

  turma      Turma       @relation(fields: [turmaId], references: [id])
  assistente Usuario     @relation(fields: [assistenteId], references: [id])
  alunos     SessaoAluno[]

  @@unique([turmaId, data])
  @@map("sessoes")
}

model SessaoAluno {
  id             String        @id @default(uuid())
  sessaoId       String        @map("sessao_id")
  alunoId        String        @map("aluno_id")
  matriculaId    String        @map("matricula_id")
  presente       Boolean       @default(true)
  folhasFeitas   Int?          @map("folhas_feitas")
  acertos        Int?
  erros          Int?
  tempoMinutos   Int?          @map("tempo_minutos")
  nivelId        String?       @map("nivel_id")
  materialCodigo String?       @map("material_codigo") @db.VarChar(20)
  statusSessao   StatusSessao? @map("status_sessao")
  observacao     String?       @db.Text

  sessao    Sessao    @relation(fields: [sessaoId], references: [id])
  aluno     Aluno     @relation(fields: [alunoId], references: [id])
  matricula Matricula @relation(fields: [matriculaId], references: [id])
  nivel     Nivel?    @relation(fields: [nivelId], references: [id])

  @@unique([sessaoId, alunoId, matriculaId])
  @@map("sessao_alunos")
}

// ─── Reuniões ────────────────────────────────────────────────────────────────

model Reuniao {
  id             String   @id @default(uuid())
  alunoId        String   @map("aluno_id")
  responsavelId  String?  @map("responsavel_id")
  usuarioId      String   @map("usuario_id")
  data           DateTime @db.Date
  descricao      String   @db.Text
  tipo           String   @default("geral") @db.VarChar(50)
  criadoEm      DateTime @default(now()) @map("criado_em")

  aluno       Aluno        @relation(fields: [alunoId], references: [id])
  responsavel Responsavel? @relation(fields: [responsavelId], references: [id])
  usuario     Usuario      @relation(fields: [usuarioId], references: [id])

  @@map("reunioes")
}

// ─── Pagamentos / Mensalidades ───────────────────────────────────────────────

model Pagamento {
  id             String          @id @default(uuid())
  alunoId        String          @map("aluno_id")
  matriculaId    String          @map("matricula_id")
  responsavelId  String          @map("responsavel_id")
  mesReferencia  DateTime        @map("mes_referencia") @db.Date
  valor          Decimal         @db.Decimal(10, 2)
  vencimento     DateTime        @db.Date
  pagoEm         DateTime?       @map("pago_em") @db.Date
  formaPagamento FormaPagamento? @map("forma_pagamento")
  observacao     String?         @db.Text
  conciliado     Boolean         @default(false)
  conciliadoEm   DateTime?       @map("conciliado_em") @db.Date

  aluno       Aluno       @relation(fields: [alunoId], references: [id])
  matricula   Matricula   @relation(fields: [matriculaId], references: [id])
  responsavel Responsavel @relation(fields: [responsavelId], references: [id])
  cobrancas   Cobranca[]
  movimentos  MovimentoFinanceiro[]

  @@unique([matriculaId, mesReferencia])
  @@map("pagamentos")
}

// ─── Cobranças ───────────────────────────────────────────────────────────────

model Cobranca {
  id           String         @id @default(uuid())
  alunoId      String         @map("aluno_id")
  pagamentoId  String?        @map("pagamento_id")
  valor        Decimal        @db.Decimal(10, 2)
  vencimento   DateTime       @db.Date
  status       StatusCobranca @default(aguardando)
  descricao    String?        @db.VarChar(255)
  nossoNumero    String?        @map("nosso_numero") @db.VarChar(100)
  linhaDigitavel String?        @map("linha_digitavel") @db.VarChar(200)
  asaasId        String?        @map("asaas_id") @db.VarChar(100)
  pixQrCode      String?        @map("pix_qr_code") @db.Text
  pixChave       String?        @map("pix_chave") @db.Text
  boletoUrl      String?        @map("boleto_url") @db.Text
  criadoEm      DateTime       @default(now()) @map("criado_em")
  pagoEm         DateTime?      @map("pago_em") @db.Date

  aluno     Aluno      @relation(fields: [alunoId], references: [id])
  pagamento Pagamento? @relation(fields: [pagamentoId], references: [id])

  @@map("cobrancas")
}

// ─── Movimento Financeiro ────────────────────────────────────────────────────

model MovimentoFinanceiro {
  id           String          @id @default(uuid())
  tipo         TipoMovimento
  origem       OrigemMovimento @default(outro)
  descricao    String          @db.VarChar(255)
  valor        Decimal         @db.Decimal(10, 2)
  data         DateTime        @db.Date
  status       StatusMovimento @default(confirmado)
  pagamentoId  String?         @map("pagamento_id")
  observacao   String?         @db.Text
  criadoEm    DateTime        @default(now()) @map("criado_em")

  pagamento Pagamento? @relation(fields: [pagamentoId], references: [id])

  @@map("movimentos_financeiros")
}

// ─── Recorrências ────────────────────────────────────────────────────────────

model ConfigRecorrencia {
  id              String          @id @default(uuid())
  nome            String          @db.VarChar(100)
  valor           Decimal         @db.Decimal(10, 2)
  periodicidade   TipoRecorrencia
  diaVencimento   Int             @map("dia_vencimento")
  dataInicio      DateTime        @map("data_inicio") @db.Date
  dataFim         DateTime?       @map("data_fim") @db.Date
  ativo           Boolean         @default(true)
  descricao       String?         @db.VarChar(255)
  criadoEm       DateTime        @default(now()) @map("criado_em")

  @@map("config_recorrencias")
}

// ─── Notas Fiscais ───────────────────────────────────────────────────────────

model NotaFiscal {
  id            String           @id @default(uuid())
  alunoId       String           @map("aluno_id")
  responsavelId String?          @map("responsavel_id")
  numero        String?          @db.VarChar(50)
  valor         Decimal          @db.Decimal(10, 2)
  competencia   DateTime         @db.Date
  status        StatusNotaFiscal @default(rascunho)
  descricao     String?          @db.VarChar(255)
  xmlUrl        String?          @map("xml_url") @db.VarChar(500)
  criadoEm     DateTime         @default(now()) @map("criado_em")
  emitidaEm    DateTime?        @map("emitida_em")

  aluno       Aluno        @relation(fields: [alunoId], references: [id])
  responsavel Responsavel? @relation(fields: [responsavelId], references: [id])

  @@map("notas_fiscais")
}

// ─── Configurações da Empresa ────────────────────────────────────────────────

model ConfigEmpresa {
  id          String   @id @default(uuid())
  nome        String   @db.VarChar(200)
  cnpj        String?  @db.VarChar(18)
  logo        String?  @db.Text
  cep         String?  @db.VarChar(9)
  rua         String?  @db.VarChar(200)
  numero      String?  @db.VarChar(20)
  complemento String?  @db.VarChar(100)
  bairro      String?  @db.VarChar(100)
  cidade      String?  @db.VarChar(100)
  estado      String?  @db.VarChar(2)
  atualizadoEm DateTime @default(now()) @updatedAt @map("atualizado_em")

  @@map("config_empresa")
}

// ─── Gateway de Pagamento ─────────────────────────────────────────────────────

model ConfigGateway {
  id        String   @id @default(uuid())
  tipo      String   @db.VarChar(50)
  ambiente  String   @db.VarChar(20)
  apiKey    String   @db.Text @map("api_key")
  ativo     Boolean  @default(true)
  criadoEm DateTime @default(now()) @map("criado_em")

  @@map("config_gateway")
}

// ─── Exercícios e Correção Inteligente ───────────────────────────────────────

model Exercicio {
  id          String   @id @default(uuid())
  titulo      String   @db.VarChar(200)
  descricao   String?  @db.Text
  materiaId   String?  @map("materia_id")
  nivelId     String?  @map("nivel_id")
  ativo       Boolean  @default(true)
  criadoEm   DateTime @default(now()) @map("criado_em")

  materia       Materia?       @relation(fields: [materiaId], references: [id])
  nivel         Nivel?         @relation(fields: [nivelId], references: [id])
  questoes      Questao[]
  tentativas    Tentativa[]
  tentativasOcr TentativaOcr[]

  @@map("exercicios")
}

model Questao {
  id          String      @id @default(uuid())
  exercicioId String      @map("exercicio_id")
  enunciado   String      @db.Text
  tipo        TipoQuestao
  ordem       Int         @default(0)
  pontos      Decimal     @default(1) @db.Decimal(5, 2)

  exercicio               Exercicio               @relation(fields: [exercicioId], references: [id], onDelete: Cascade)
  alternativas            Alternativa[]
  respostaCorreta         RespostaCorreta?
  respostasAluno          RespostaAluno[]
  errosRecorrentes        ErroRecorrente[]
  respostasOcrDetectadas  RespostaOcrDetectada[]

  @@map("questoes")
}

model Alternativa {
  id        String  @id @default(uuid())
  questaoId String  @map("questao_id")
  letra     String  @db.VarChar(1)
  texto     String  @db.Text

  questao          Questao          @relation(fields: [questaoId], references: [id], onDelete: Cascade)
  respostasAluno   RespostaAluno[]

  @@map("alternativas")
}

model RespostaCorreta {
  id            String   @id @default(uuid())
  questaoId     String   @unique @map("questao_id")
  alternativaId String?  @map("alternativa_id")
  valorNumerico Decimal? @map("valor_numerico") @db.Decimal(15, 4)
  tolerancia    Decimal? @db.Decimal(10, 4)
  textoEsperado String?  @map("texto_esperado") @db.Text

  questao Questao @relation(fields: [questaoId], references: [id], onDelete: Cascade)

  @@map("respostas_corretas")
}

model Tentativa {
  id           String    @id @default(uuid())
  alunoId      String    @map("aluno_id")
  exercicioId  String    @map("exercicio_id")
  iniciadaEm   DateTime  @default(now()) @map("iniciada_em")
  finalizadaEm DateTime? @map("finalizada_em")
  pontuacao    Decimal?  @db.Decimal(5, 2)
  totalPontos  Decimal?  @map("total_pontos") @db.Decimal(5, 2)
  corrigida    Boolean   @default(false)

  aluno          Aluno           @relation(fields: [alunoId], references: [id])
  exercicio      Exercicio       @relation(fields: [exercicioId], references: [id])
  respostasAluno RespostaAluno[]
  tentativaOcr   TentativaOcr?

  @@map("tentativas")
}

model RespostaAluno {
  id            String   @id @default(uuid())
  tentativaId   String   @map("tentativa_id")
  questaoId     String   @map("questao_id")
  alternativaId String?  @map("alternativa_id")
  valorNumerico Decimal? @map("valor_numerico") @db.Decimal(15, 4)
  textoResposta String?  @map("texto_resposta") @db.Text
  correta       Boolean?
  pontosObtidos Decimal? @map("pontos_obtidos") @db.Decimal(5, 2)

  tentativa   Tentativa    @relation(fields: [tentativaId], references: [id], onDelete: Cascade)
  questao     Questao      @relation(fields: [questaoId], references: [id])
  alternativa Alternativa? @relation(fields: [alternativaId], references: [id])

  @@unique([tentativaId, questaoId])
  @@map("respostas_aluno")
}

model ErroRecorrente {
  id               String   @id @default(uuid())
  alunoId          String   @map("aluno_id")
  questaoId        String   @map("questao_id")
  contagem         Int      @default(1)
  ultimaOcorrencia DateTime @default(now()) @map("ultima_ocorrencia")
  resolvido        Boolean  @default(false)

  aluno     Aluno            @relation(fields: [alunoId], references: [id])
  questao   Questao          @relation(fields: [questaoId], references: [id])
  sugestoes SugestaoReforco[]

  @@unique([alunoId, questaoId])
  @@map("erros_recorrentes")
}

model SugestaoReforco {
  id               String   @id @default(uuid())
  alunoId          String   @map("aluno_id")
  erroRecorrenteId String   @map("erro_recorrente_id")
  texto            String   @db.Text
  criadoEm        DateTime @default(now()) @map("criado_em")
  visualizada      Boolean  @default(false)

  aluno          Aluno          @relation(fields: [alunoId], references: [id])
  erroRecorrente ErroRecorrente @relation(fields: [erroRecorrenteId], references: [id])

  @@map("sugestoes_reforco")
}

// ─── OCR — Correção por Fotografia ───────────────────────────────────────────

model TentativaOcr {
  id            String    @id @default(uuid())
  alunoId       String    @map("aluno_id")
  exercicioId   String    @map("exercicio_id")
  arquivoBase64 String    @db.Text @map("arquivo_base64")
  tipoArquivo   String    @default("image/jpeg") @map("tipo_arquivo") @db.VarChar(30)
  textoOcr      String?   @db.Text @map("texto_ocr")
  status        StatusOcr @default(pendente)
  erroMensagem  String?   @db.Text @map("erro_mensagem")
  tentativaId   String?   @unique @map("tentativa_id")
  criadoEm     DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  aluno               Aluno                  @relation(fields: [alunoId], references: [id])
  exercicio           Exercicio              @relation(fields: [exercicioId], references: [id])
  tentativa           Tentativa?             @relation(fields: [tentativaId], references: [id])
  respostasDetectadas RespostaOcrDetectada[]

  @@map("tentativas_ocr")
}

model RespostaOcrDetectada {
  id              String   @id @default(uuid())
  tentativaOcrId  String   @map("tentativa_ocr_id")
  questaoOrdem    Int      @map("questao_ordem")
  questaoId       String?  @map("questao_id")
  tipoQuestao     String   @map("tipo_questao") @db.VarChar(20)
  // O que o OCR detectou (nunca muda após processamento)
  letraDetectada  String?  @map("letra_detectada") @db.VarChar(1)
  valorDetectado  Decimal? @map("valor_detectado") @db.Decimal(15, 4)
  confianca       Decimal? @db.Decimal(4, 3)
  // O que o usuário confirmou na revisão (pode diferir do OCR)
  letraFinal      String?  @map("letra_final") @db.VarChar(1)
  valorFinal      Decimal? @map("valor_final") @db.Decimal(15, 4)
  revisadaManual  Boolean  @default(false) @map("revisada_manual")

  tentativaOcr TentativaOcr @relation(fields: [tentativaOcrId], references: [id], onDelete: Cascade)
  questao      Questao?      @relation(fields: [questaoId], references: [id])

  @@map("respostas_ocr_detectadas")
}
