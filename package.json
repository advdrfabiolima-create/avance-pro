{
  "name": "kumon-advance",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:desktop": "pnpm --filter desktop dev",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "build:desktop": "pnpm --filter desktop build",
    "db:migrate": "pnpm --filter @kumon-advance/db migrate",
    "db:generate": "pnpm --filter @kumon-advance/db generate",
    "db:studio": "pnpm --filter @kumon-advance/db studio",
    "db:seed": "pnpm --filter @kumon-advance/db seed",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
