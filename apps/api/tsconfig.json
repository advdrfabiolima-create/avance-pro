{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "5.0",
    "lib": ["ES2022"],
    "exactOptionalPropertyTypes": false,
    "strict": false,
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": false
  },
  "include": ["src"]
}
